# ---------------------------------------------------------------------------
# .env.example — ChatPy V2
# ---------------------------------------------------------------------------
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# NUNCA commite o arquivo .env real (ele contém segredos).
#
# 💡 DICA: Você NÃO PRECISA criar este arquivo para testar o ChatPy!
# O servidor auto-gera o JWT_SECRET na primeira execução.
# Este arquivo é para configuração avançada/produção.
# ---------------------------------------------------------------------------

# Chave secreta para assinar tokens JWT
# Se não configurada, é AUTO-GERADA e salva em .chatpy_auto_secret
# Para produção, defina explicitamente:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-uma-chave-aleatoria-longa-e-segura-de-pelo-menos-32-caracteres

# Banco de dados (default: SQLite — zero configuração)
# Para Postgres, use: postgresql://chatpy_user:chatpy_pass@chatpy-db:5432/chatpy
DATABASE_URL=sqlite:////app/data/chatpy.db

# CORS — origens permitidas, separadas por vírgula
# Use * para permitir todas (não recomendado para produção)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Formato de log: text (legível) ou json (estruturado para produção)
LOG_FORMAT=text

# Diretório de uploads
UPLOAD_DIR=uploads

# Backup automático SQLite (recomendado para produção)
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP_COUNT=7

# Rate limiting (padrões seguros — ajuste se necessário)
REST_RATE_LIMIT_ENABLED=true
REST_RATE_LIMIT_PER_MINUTE=60

# Federação (desativada por padrão)
FEDERATION_ENABLED=false
# FEDERATION_OPEN=false
# CHATPY_SERVER_DOMAIN=chatpy.seudominio.com
# CHATPY_SERVER_BASE_URL=https://chatpy.seudominio.com

# LAN discovery (ativado por padrão — permite descoberta via mDNS)
LAN_DISCOVERY_ENABLED=true

# Modo convidado
GUEST_TTL_HOURS=24

# --- Postgres (apenas se for usar profile 'database') ---
POSTGRES_USER=chatpy_user
POSTGRES_PASSWORD=chatpy_pass
POSTGRES_DB=chatpy
